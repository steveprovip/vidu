@model DangNhapViewModel
@{ ViewData["Title"] = "Đăng nhập"; Layout = null; }

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - FreshCare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { min-height: 100vh; background: linear-gradient(135deg, #1b4332 0%, #2d6a4f 50%, #40916c 100%); display: flex; align-items: center; justify-content: center; }
        .login-card { background: rgba(255,255,255,0.95); border-radius: 24px; padding: 3rem; max-width: 440px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.3); backdrop-filter: blur(10px); }
        .login-card .brand { text-align: center; margin-bottom: 2rem; }
        .login-card .brand h1 { font-weight: 700; color: #1b4332; font-size: 2rem; }
        .login-card .brand p { color: #666; font-size: 0.9rem; }
        .login-card .brand .icon-circle { width: 80px; height: 80px; background: linear-gradient(135deg, #2d6a4f, #52b788); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
        .login-card .brand .icon-circle i { font-size: 2rem; color: #fff; }
        .form-control { border-radius: 12px; padding: 0.75rem 1rem; border: 2px solid #e9ecef; }
        .form-control:focus { border-color: #2d6a4f; box-shadow: 0 0 0 0.2rem rgba(45,106,79,0.15); }
        .btn-login { background: linear-gradient(135deg, #2d6a4f, #40916c); border: none; border-radius: 12px; padding: 0.75rem; font-weight: 600; font-size: 1.05rem; width: 100%; color: #fff; transition: transform 0.2s; }
        .btn-login:hover { transform: translateY(-2px); color: #fff; box-shadow: 0 6px 20px rgba(45,106,79,0.4); }
        .register-link { text-align: center; margin-top: 1.5rem; }
        .register-link a { color: #2d6a4f; font-weight: 600; text-decoration: none; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand">
            <div class="icon-circle"><i class="fas fa-leaf"></i></div>
            <h1>FreshCare</h1>
            <p>Hệ thống Quản lý Kho & Hạn sử dụng<br/>Cửa hàng Thực phẩm sạch</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="DangNhap" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-semibold"><i class="fas fa-user me-2"></i>Tên đăng nhập</label>
                <input asp-for="TenDangNhap" class="form-control" placeholder="Nhập tên đăng nhập" autofocus />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold"><i class="fas fa-lock me-2"></i>Mật khẩu</label>
                <input asp-for="MatKhau" type="password" class="form-control" placeholder="Nhập mật khẩu" />
            </div>

            <button type="submit" class="btn btn-login">
                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
            </button>
        </form>

        <div class="register-link">
            <span class="text-muted">Chưa có tài khoản?</span>
            <a href="/TaiKhoan/DangKy">Đăng ký ngay</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
