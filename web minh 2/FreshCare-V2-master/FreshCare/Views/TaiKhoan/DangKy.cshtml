@model DangKyViewModel
@{ ViewData["Title"] = "Đăng ký"; Layout = null; }

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - FreshCare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { min-height: 100vh; background: linear-gradient(135deg, #1b4332 0%, #2d6a4f 50%, #40916c 100%); display: flex; align-items: center; justify-content: center; }
        .register-card { background: rgba(255,255,255,0.95); border-radius: 24px; padding: 3rem; max-width: 480px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
        .brand { text-align: center; margin-bottom: 2rem; }
        .brand h2 { font-weight: 700; color: #1b4332; }
        .form-control { border-radius: 12px; padding: 0.75rem 1rem; border: 2px solid #e9ecef; }
        .form-control:focus { border-color: #2d6a4f; box-shadow: 0 0 0 0.2rem rgba(45,106,79,0.15); }
        .btn-register { background: linear-gradient(135deg, #2d6a4f, #40916c); border: none; border-radius: 12px; padding: 0.75rem; font-weight: 600; width: 100%; color: #fff; }
        .btn-register:hover { color: #fff; box-shadow: 0 6px 20px rgba(45,106,79,0.4); }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="brand">
            <i class="fas fa-leaf fa-2x text-success mb-2"></i>
            <h2>Đăng ký tài khoản</h2>
            <p class="text-muted">Nhân viên kho FreshCare</p>
        </div>

        <form asp-action="DangKy" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-semibold"><i class="fas fa-user me-2"></i>Họ và tên</label>
                <input asp-for="HoTen" class="form-control" placeholder="Nhập họ tên đầy đủ" />
                <span asp-validation-for="HoTen" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold"><i class="fas fa-id-card me-2"></i>Tên đăng nhập</label>
                <input asp-for="TenDangNhap" class="form-control" placeholder="Tối thiểu 4 ký tự" />
                <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold"><i class="fas fa-lock me-2"></i>Mật khẩu</label>
                <input asp-for="MatKhau" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" />
                <span asp-validation-for="MatKhau" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold"><i class="fas fa-lock me-2"></i>Xác nhận mật khẩu</label>
                <input asp-for="XacNhanMatKhau" type="password" class="form-control" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-register"><i class="fas fa-user-plus me-2"></i>Đăng ký</button>
        </form>

        <div class="text-center mt-3">
            <a href="/TaiKhoan/DangNhap" class="text-decoration-none" style="color:#2d6a4f;font-weight:600;">
                <i class="fas fa-arrow-left me-1"></i>Quay lại Đăng nhập
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
