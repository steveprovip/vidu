@model NhapKhoViewModel
@{ ViewData["Title"] = "Nhập kho - Tạo lô hàng mới"; }

<h4 class="section-title"><i class="fas fa-download me-2"></i>Nhập Kho — Tạo Lô Hàng Mới</h4>

<div class="row">
    <div class="col-md-8">
        <div class="card card-fc">
            <div class="card-body">
                <form asp-action="NhapMoi" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Quét mã vạch nhanh (Luật #14) -->
                    <div class="mb-3 p-3 bg-light rounded">
                        <label class="form-label fw-semibold"><i class="fas fa-barcode me-1 text-primary"></i>Quét mã vạch (tùy chọn)</label>
                        <div class="input-group">
                            <input type="text" id="txtMaVach" class="form-control" placeholder="Quét hoặc nhập mã vạch sản phẩm..." />
                            <button type="button" class="btn btn-outline-primary" id="btnQuetMa"><i class="fas fa-search me-1"></i>Tìm</button>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold"><i class="fas fa-box me-1"></i>Sản phẩm <span class="text-danger">*</span></label>
                            <select asp-for="MaSP" class="form-select" id="ddlSanPham" required>
                                <option value="">-- Chọn sản phẩm --</option>
                                @foreach (var sp in Model.DanhSachSanPham)
                                {
                                    <option value="@sp.MaSP" data-dvt="@sp.DonViTinh" data-gia='@sp.GiaBan.ToString(System.Globalization.CultureInfo.InvariantCulture)'>
                                        @sp.TenSP (@sp.DonViTinh) - @sp.TenDanhMuc
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold"><i class="fas fa-weight-hanging me-1"></i>Số lượng <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="SoLuong" type="number" step="0.01" min="0.01" class="form-control" id="txtSoLuong" required />
                                <span class="input-group-text" id="lblDonViTinh">---</span>
                            </div>
                        </div>

                        <!-- Thông tin giá -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><i class="fas fa-tag me-1"></i>Giá bán hiện tại</label>
                            <div class="input-group">
                                <input type="text" id="txtGiaBan" class="form-control" readonly disabled />
                                <span class="input-group-text">đ</span>
                            </div>
                            <small class="text-muted">
                                <a href="/SanPham/DanhSach" target="_blank">
                                    <i class="fas fa-edit me-1"></i>Thay đổi giá bán tại Quản lý SP
                                </a>
                            </small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><i class="fas fa-calculator me-1"></i>Thành tiền (ước tính)</label>
                            <div class="input-group">
                                <input type="text" id="txtThanhTien" class="form-control fw-bold text-primary" readonly disabled />
                                <span class="input-group-text">đ</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><i class="fas fa-calendar-day me-1"></i>Ngày sản xuất (NSX) <span class="text-danger">*</span></label>
                            <input asp-for="NgaySanXuat" type="date" class="form-control" id="txtNSX" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><i class="fas fa-calendar-check me-1"></i>Hạn sử dụng (HSD) <span class="text-danger">*</span></label>
                            <input asp-for="HanSuDung" type="date" class="form-control" id="txtHSD" required />
                            <small class="text-muted">⚠️ Luật: HSD phải ≥ NSX</small>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold"><i class="fas fa-sticky-note me-1"></i>Ghi chú</label>
                            <textarea asp-for="GhiChu" class="form-control" rows="2" placeholder="Ghi chú thêm (không bắt buộc)"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-fc-primary btn-lg">
                            <i class="fas fa-save me-2"></i>Lưu Phiếu Nhập
                        </button>
                        <a href="/Home/Index" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-arrow-left me-1"></i>Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-fc mb-3">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="fas fa-info-circle me-2 text-primary"></i>Hướng dẫn nhập kho</h6>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Chọn sản phẩm hoặc quét mã vạch</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Nhập số lượng (Kg cho phép thập phân)</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>NSX & HSD ghi trên bao bì</li>
                    <li class="mb-2"><i class="fas fa-exclamation-triangle text-warning me-2"></i><strong>HSD phải ≥ NSX</strong></li>
                    <li class="mb-2"><i class="fas fa-cube text-primary me-2"></i>Hệ thống tự sinh mã lô (Batch ID)</li>
                    <li><i class="fas fa-link text-info me-2"></i>Chưa có SP? <a href="/SanPham/DanhSach">Thêm tại đây</a></li>
                </ul>
            </div>
        </div>

        <!-- Hiển thị thông tin sản phẩm đã chọn -->
        <div class="card card-fc d-none" id="cardThongTinSP">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="fas fa-box-open me-2"></i>Sản phẩm đã chọn</h6>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong id="infoTenSP">---</strong></p>
                <p class="mb-1 text-muted">Đơn vị: <span id="infoDVT">---</span></p>
                <p class="mb-0">Giá bán: <span class="fw-bold text-success" id="infoGia">---</span></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Luật #14: AJAX cập nhật đơn vị tính không reload
    $('#ddlSanPham').on('change', function () {
        var selected = $(this).find('option:selected');
        var maSP = $(this).val();

        if (!maSP) {
            $('#lblDonViTinh').text('---');
            $('#txtGiaBan').val('');
            $('#txtThanhTien').val('');
            $('#cardThongTinSP').addClass('d-none');
            return;
        }

        var dvt = selected.data('dvt');
        var gia = selected.data('gia');
        var tenSP = selected.text().split('(')[0].trim();

        $('#lblDonViTinh').text(dvt);
        $('#txtGiaBan').val(Number(gia).toLocaleString('vi-VN'));

        // Luật #10: Bó/Hộp/Khay/Chai/Vỉ... → số nguyên, (Kg, Lít, Mili-lít) → thập phân
        var decimalUnits = ['Kg', 'Lít', 'Mili-lít', 'Mi-li-lít'];
        if (decimalUnits.includes(dvt)) {
            $('#txtSoLuong').attr('step', '0.01').attr('min', '0.01');
        } else {
            $('#txtSoLuong').attr('step', '1').attr('min', '1');
            var val = Math.round($('#txtSoLuong').val());
            if (val < 1) val = 1;
            $('#txtSoLuong').val(val);
        }

        // Hiển thị info card
        $('#infoTenSP').text(tenSP);
        $('#infoDVT').text(dvt);
        $('#infoGia').text(Number(gia).toLocaleString('vi-VN') + 'đ');
        $('#cardThongTinSP').removeClass('d-none');

        tinhThanhTien();
    });

    // Tính thành tiền khi thay đổi số lượng
    $('#txtSoLuong').on('input', function () { tinhThanhTien(); });

    function tinhThanhTien() {
        var sl = parseFloat($('#txtSoLuong').val()) || 0;
        var gia = parseFloat($('#ddlSanPham option:selected').data('gia')) || 0;
        var total = sl * gia;
        $('#txtThanhTien').val(total.toLocaleString('vi-VN'));
    }

    // Luật #14: Quét mã vạch
    $('#btnQuetMa').on('click', function () {
        var maVach = $('#txtMaVach').val().trim();
        if (!maVach) return;

        $.get('/SanPham/TimTheoMaVach', { maVach: maVach }, function (data) {
            if (data.success) {
                $('#ddlSanPham').val(data.maSP).trigger('change');
                $('#txtMaVach').val('').addClass('is-valid');
                setTimeout(function() { $('#txtMaVach').removeClass('is-valid'); }, 2000);
            } else {
                $('#txtMaVach').addClass('is-invalid');
                setTimeout(function() { $('#txtMaVach').removeClass('is-invalid'); }, 2000);
            }
        });
    });

    // Enter key để quét mã vạch
    $('#txtMaVach').on('keypress', function (e) {
        if (e.which === 13) {
            e.preventDefault();
            $('#btnQuetMa').click();
        }
    });

    // Validate HSD >= NSX trước khi submit
    $('form').on('submit', function (e) {
        var nsx = new Date($('#txtNSX').val());
        var hsd = new Date($('#txtHSD').val());
        if (hsd < nsx) {
            e.preventDefault();
            alert('Lỗi: Hạn sử dụng (HSD) phải lớn hơn hoặc bằng ngày sản xuất (NSX)!');
        }
    });
</script>
}
