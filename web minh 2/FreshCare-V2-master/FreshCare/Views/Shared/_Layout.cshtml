<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FreshCare</title>
    <meta name="description" content="Hệ thống Quản lý Kho & Hạn sử dụng - Cửa hàng Thực phẩm sạch FreshCare" />

    <!-- Luật #18: Bootstrap 5 + FontAwesome 6 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --fc-primary: #2d6a4f;
            --fc-primary-light: #40916c;
            --fc-secondary: #52b788;
            --fc-dark: #1b4332;
            --fc-light: #d8f3dc;
            --fc-bg: #f8f9fa;
            --fc-danger: #e63946;
            --fc-warning: #f4a261;
            --fc-success: #2a9d8f;
        }

        * { font-family: 'Inter', sans-serif; }

        body {
            background: var(--fc-bg);
            min-height: 100vh;
        }

        /* Luật #15: Navbar cố định */
        .navbar-freshcare {
            background: linear-gradient(135deg, var(--fc-dark) 0%, var(--fc-primary) 100%);
            box-shadow: 0 2px 15px rgba(0,0,0,0.15);
            padding: 0.6rem 1rem;
        }
        .navbar-freshcare .navbar-brand {
            font-weight: 700;
            font-size: 1.3rem;
            color: #fff !important;
            letter-spacing: 0.5px;
        }
        .navbar-freshcare .navbar-brand i { color: var(--fc-secondary); }
        .navbar-freshcare .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: all 0.2s;
            margin: 0 2px;
        }
        .navbar-freshcare .nav-link:hover,
        .navbar-freshcare .nav-link.active {
            color: #fff !important;
            background: rgba(255,255,255,0.15);
        }
        .navbar-freshcare .dropdown-menu {
            border: none;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            border-radius: 12px;
        }

        .main-content { padding: 1.5rem 0; }

        /* Card styles */
        .card-fc {
            border: none;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card-fc:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        }

        /* Dashboard stat cards */
        .stat-card {
            border-radius: 16px;
            padding: 1.2rem;
            color: #fff;
            position: relative;
            overflow: hidden;
        }
        .stat-card .stat-icon {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 3rem;
            opacity: 0.2;
        }
        .stat-card h3 { font-size: 2rem; font-weight: 700; margin: 0; }
        .stat-card p { margin: 0; font-size: 0.9rem; opacity: 0.9; }

        .bg-fc-danger { background: linear-gradient(135deg, #e63946, #c1121f); }
        .bg-fc-warning { background: linear-gradient(135deg, #f4a261, #e76f51); }
        .bg-fc-success { background: linear-gradient(135deg, #2a9d8f, #2d6a4f); }
        .bg-fc-info { background: linear-gradient(135deg, #457b9d, #1d3557); }

        /* Table styles */
        .table-fc thead th {
            background: var(--fc-dark);
            color: #fff;
            font-weight: 600;
            border: none;
            font-size: 0.85rem;
        }
        .table-fc tbody td { vertical-align: middle; font-size: 0.9rem; }

        /* Badges */
        .badge-qua-han { background: var(--fc-danger); }
        .badge-can-date { background: var(--fc-warning); color: #333; }
        .badge-an-toan { background: var(--fc-success); }

        /* Toast styles (Luật #19) */
        .toast-container { position: fixed; top: 80px; right: 20px; z-index: 9999; }

        /* Price styling */
        .gia-goc { text-decoration: line-through; color: #999; font-size: 0.85rem; }
        .gia-sale { color: var(--fc-danger); font-weight: 700; }

        /* Form styles */
        .form-control:focus, .form-select:focus {
            border-color: var(--fc-primary);
            box-shadow: 0 0 0 0.2rem rgba(45,106,79,0.2);
        }

        .btn-fc-primary {
            background: var(--fc-primary);
            border: none;
            color: #fff;
            border-radius: 10px;
            font-weight: 600;
            padding: 0.6rem 1.5rem;
        }
        .btn-fc-primary:hover {
            background: var(--fc-primary-light);
            color: #fff;
        }

        .btn-fc-danger {
            background: var(--fc-danger);
            border: none;
            color: #fff;
            border-radius: 10px;
        }

        .section-title {
            font-weight: 700;
            color: var(--fc-dark);
            border-bottom: 3px solid var(--fc-secondary);
            padding-bottom: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .user-info {
            color: rgba(255,255,255,0.7);
            font-size: 0.85rem;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    @if (Context.Session.GetInt32("MaNV") != null)
    {
        <!-- Luật #15: Navbar cố định: Trang chủ, Quản lý sản phẩm, Báo cáo, Tài khoản -->
        <nav class="navbar navbar-expand-lg navbar-freshcare sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand" href="/Home/Index">
                    <i class="fas fa-leaf me-2"></i>FreshCare
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <!-- 1. Trang chủ (Dashboard) -->
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index">
                                <i class="fas fa-home me-1"></i> Trang chủ
                            </a>
                        </li>

                        <!-- 2. Quản lý sản phẩm -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-boxes-stacked me-1"></i> Quản lý sản phẩm
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/SanPham/DanhMuc"><i class="fas fa-tags me-2"></i>Danh mục</a></li>
                                <li><a class="dropdown-item" href="/SanPham/DanhSach"><i class="fas fa-box me-2"></i>Sản phẩm</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" href="/NhapKho/Index"><i class="fas fa-download me-2"></i>Nhập kho</a></li>
                                <li><a class="dropdown-item" href="/XuatKho/BanHang"><i class="fas fa-upload me-2"></i>Xuất kho (Bán hàng)</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" href="/NhapKho/LichSu"><i class="fas fa-file-import me-2"></i>Lịch sử nhập</a></li>
                                <li><a class="dropdown-item" href="/XuatKho/LichSu"><i class="fas fa-file-export me-2"></i>Lịch sử xuất</a></li>
                            </ul>
                        </li>

                        <!-- 3. Báo cáo -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-chart-bar me-1"></i> Báo cáo
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/BaoCao/TonKho"><i class="fas fa-warehouse me-2"></i>Tồn kho</a></li>
                                @if (Context.Session.GetString("VaiTro") == "Admin")
                                {
                                    <li><a class="dropdown-item" href="/BaoCao/DoanhThu"><i class="fas fa-coins me-2"></i>Doanh thu & Hao hụt</a></li>
                                }
                            </ul>
                        </li>

                        <!-- 4. Tài khoản -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i> Tài khoản
                            </a>
                            <ul class="dropdown-menu">
                                @if (Context.Session.GetString("VaiTro") == "Admin")
                                {
                                    <li><a class="dropdown-item" href="/TaiKhoan/QuanLy"><i class="fas fa-users-cog me-2"></i>Quản lý nhân viên</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                <li>
                                    <a class="dropdown-item text-danger" href="/TaiKhoan/DangXuat">
                                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>

                    <span class="user-info">
                        <i class="fas fa-user me-1"></i>
                        @Context.Session.GetString("HoTen")
                        <span class="badge bg-light text-dark ms-1">@Context.Session.GetString("VaiTro")</span>
                    </span>
                </div>
            </div>
        </nav>
    }

    <!-- Luật #19: Toast Notifications bằng TempData -->
    <div class="toast-container">
        @if (TempData["Success"] != null)
        {
            <div class="toast show align-items-center text-bg-success border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast show align-items-center text-bg-danger border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
    </div>

    <div class="container-fluid main-content">
        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
        // Auto-hide toast after 5 seconds
        setTimeout(function () {
            document.querySelectorAll('.toast.show').forEach(function (t) {
                var bsToast = new bootstrap.Toast(t);
                bsToast.hide();
            });
        }, 5000);
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
