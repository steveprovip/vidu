@model List<DanhMuc>
@{ ViewData["Title"] = "Quản lý Danh mục"; }

<h4 class="section-title"><i class="fas fa-tags me-2"></i>Quản Lý Danh Mục Sản Phẩm</h4>

<div class="row">
    <div class="col-md-5">
        <div class="card card-fc">
            <div class="card-header bg-light"><h6 class="mb-0"><i class="fas fa-plus-circle me-2 text-success"></i>Thêm danh mục mới</h6></div>
            <div class="card-body">
                <form asp-action="ThemDanhMuc" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên danh mục</label>
                        <input name="tenDanhMuc" class="form-control" placeholder="VD: Rau Củ Quả" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">% Giảm giá khi cận date</label>
                        <div class="input-group">
                            <input name="phanTramSale" type="number" step="1" min="0" max="100" class="form-control" value="20" required />
                            <span class="input-group-text">%</span>
                        </div>
                        <small class="text-muted">Áp dụng tự động khi lô hàng thuộc danh mục này cận date</small>
                    </div>
                    <button type="submit" class="btn btn-fc-primary"><i class="fas fa-save me-1"></i>Lưu danh mục</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card card-fc">
            <div class="card-body p-0">
                <table class="table table-fc table-hover mb-0">
                    <thead>
                        <tr><th>Mã</th><th>Tên danh mục</th><th>% Sale cận date</th><th>Thao tác</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var dm in Model)
                        {
                            <tr>
                                <td>DM-@dm.MaDanhMuc.ToString("D2")</td>
                                <td><strong>@dm.TenDanhMuc</strong></td>
                                <td><span class="badge bg-danger">Giảm @dm.PhanTramSale%</span></td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary btn-sua-dm"
                                            data-id="@dm.MaDanhMuc"
                                            data-ten="@dm.TenDanhMuc"
                                            data-sale="@dm.PhanTramSale">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa Danh Mục (ĐẶT NGOÀI TABLE để tránh flickering) -->
<div class="modal fade" id="modalSuaDanhMuc" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-header" style="background:var(--fc-primary);color:#fff;border-radius:16px 16px 0 0;">
                <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Sửa danh mục</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SuaDanhMuc" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="maDanhMuc" id="editMaDanhMuc" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên danh mục</label>
                        <input name="tenDanhMuc" id="editTenDanhMuc" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">% Sale</label>
                        <div class="input-group">
                            <input name="phanTramSale" id="editPhanTramSale" type="number" step="1" min="0" max="100" class="form-control" required />
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-fc-primary"><i class="fas fa-save me-1"></i>Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Xử lý nút sửa — Điền dữ liệu vào 1 modal duy nhất
    $(document).on('click', '.btn-sua-dm', function () {
        var id = $(this).data('id');
        var ten = $(this).data('ten');
        var sale = $(this).data('sale');

        $('#editMaDanhMuc').val(id);
        $('#editTenDanhMuc').val(ten);
        $('#editPhanTramSale').val(sale);

        var modal = new bootstrap.Modal(document.getElementById('modalSuaDanhMuc'));
        modal.show();
    });
</script>
}
